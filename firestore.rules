rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Hackathon test mode: allow all reads/writes for a limited time.
    // IMPORTANT: tighten these rules before production.
    match /{document=**} {
      allow read, write: if request.time < timestamp.date(2026, 7, 1);
    }
  }
}
